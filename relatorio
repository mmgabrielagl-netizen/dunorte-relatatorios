<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dunorte Truck — Central de Relatórios</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--navy:#0B1E35;--navy3:#1a3a5c;--yellow:#F5A800;--yellow2:#e09600;--white:#fff;--mist:#EEF3F9;--text:#0B1E35;--sub:#5C7A99;--border:#D0DCEB;--red:#E84545;}
    body{font-family:'Inter',sans-serif;background:var(--mist);color:var(--text);min-height:100vh;}
    #login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(145deg,var(--navy) 0%,var(--navy3) 100%);padding:24px;}
    .login-box{background:white;border-radius:20px;padding:44px 40px;width:100%;max-width:400px;box-shadow:0 32px 80px rgba(0,0,0,.35);}
    .login-logo{text-align:center;margin-bottom:28px;}
    .login-logo img{height:110px;width:auto;}
    .login-subtitle{text-align:center;font-size:13px;color:var(--sub);margin-top:10px;font-weight:500;}
    .divider{height:1px;background:var(--border);margin:22px 0;}
    .field{margin-bottom:16px;}
    .field label{display:block;font-size:11px;font-weight:700;color:var(--text);margin-bottom:6px;text-transform:uppercase;letter-spacing:.8px;}
    .field input{width:100%;padding:13px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:inherit;outline:none;transition:border .2s;}
    .field input:focus{border-color:var(--yellow);box-shadow:0 0 0 3px rgba(245,168,0,.12);}
    .btn-login{width:100%;padding:14px;background:var(--yellow);color:var(--navy);border:none;border-radius:10px;font-size:15px;font-weight:800;cursor:pointer;font-family:inherit;transition:background .2s;margin-top:6px;}
    .btn-login:hover{background:var(--yellow2);}
    .btn-login:disabled{opacity:.6;cursor:not-allowed;}
    .login-error{color:var(--red);font-size:13px;margin-top:10px;text-align:center;display:none;}
    #app-screen{display:none;}
    .sidebar{position:fixed;top:0;left:0;width:240px;height:100vh;background:var(--navy);display:flex;flex-direction:column;z-index:100;overflow-y:auto;}
    .sidebar-logo{padding:22px 20px;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0;}
    .sidebar-logo img{height:52px;width:auto;}
    .sidebar-logo .tagline{font-size:10px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:1.5px;margin-top:8px;}
    .nav-group{padding:16px 10px 0;}
    .nav-label{font-size:9px;text-transform:uppercase;letter-spacing:1.8px;color:rgba(255,255,255,.3);padding:0 10px;margin-bottom:6px;}
    .nav-item{display:flex;align-items:center;gap:9px;padding:10px 12px;border-radius:8px;color:rgba(255,255,255,.55);font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;border:none;background:none;width:100%;text-align:left;font-family:inherit;}
    .nav-item:hover{background:rgba(255,255,255,.07);color:white;}
    .nav-item.active{background:var(--yellow);color:var(--navy);font-weight:700;}
    .sidebar-footer{margin-top:auto;padding:16px 20px;border-top:1px solid rgba(255,255,255,.08);flex-shrink:0;}
    .user-email{font-size:11px;color:rgba(255,255,255,.35);margin-bottom:8px;word-break:break-all;}
    .btn-logout{font-size:12px;color:rgba(255,255,255,.4);background:none;border:1px solid rgba(255,255,255,.12);border-radius:6px;padding:6px 12px;cursor:pointer;font-family:inherit;transition:all .2s;}
    .btn-logout:hover{color:white;border-color:rgba(255,255,255,.35);}
    .main{margin-left:240px;min-height:100vh;display:flex;flex-direction:column;}
    .topbar{background:var(--navy);border-bottom:3px solid var(--yellow);padding:12px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
    .topbar-title{font-size:15px;font-weight:700;color:white;}
    .topbar-date{font-size:12px;color:rgba(255,255,255,.5);}
    .report-frame{flex:1;width:100%;border:none;min-height:calc(100vh - 53px);}
    #home-content{padding:32px;}
    .welcome{background:var(--navy);border-radius:16px;padding:32px;margin-bottom:28px;border-left:4px solid var(--yellow);}
    .welcome h2{color:white;font-size:22px;font-weight:700;margin-bottom:6px;}
    .welcome p{color:rgba(255,255,255,.6);font-size:14px;}
    .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;}
    .rep-card{background:white;border-radius:12px;border:1px solid var(--border);padding:22px;cursor:pointer;transition:all .2s;text-align:center;}
    .rep-card:hover{border-color:var(--yellow);box-shadow:0 4px 20px rgba(245,168,0,.15);transform:translateY(-2px);}
    .rep-card-icon{font-size:36px;margin-bottom:12px;}
    .rep-card-title{font-size:14px;font-weight:700;color:var(--navy);margin-bottom:4px;}
    .rep-card-sub{font-size:12px;color:var(--sub);}
    .mobile-header{display:none;background:var(--navy);padding:14px 16px;align-items:center;justify-content:space-between;border-bottom:2px solid var(--yellow);}
    .hamburger{background:none;border:none;color:white;font-size:22px;cursor:pointer;}
    .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:90;}
    .spinner{width:15px;height:15px;border:2px solid rgba(255,255,255,.3);border-top-color:var(--yellow);border-radius:50%;animation:spin .6s linear infinite;display:inline-block;vertical-align:middle;}
    @keyframes spin{to{transform:rotate(360deg);}}
    @media(max-width:768px){
      .sidebar{transform:translateX(-100%);transition:transform .3s;}
      .sidebar.open{transform:translateX(0);}
      .sidebar-overlay.open{display:block;}
      .main{margin-left:0;}
      .mobile-header{display:flex;}
      .cards-grid{grid-template-columns:1fr 1fr;}
      #home-content{padding:16px;}
    }
  </style>
</head>
<body>

<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">
      <img src="data:image/png;base64," alt="Dunorte Truck"/>
      <div class="login-subtitle">Central de Relatórios — Acesso Interno</div>
    </div>
    <div class="divider"></div>
    <div class="field"><label>E-mail</label><input type="email" id="email" placeholder="seu@email.com"/></div>
    <div class="field"><label>Senha</label><input type="password" id="senha" placeholder="••••••••"/></div>
    <button class="btn-login" id="btn-login" onclick="login()">Entrar</button>
    <div class="login-error" id="login-error"></div>
  </div>
</div>

<div id="app-screen">
  <div class="mobile-header">
    <img src="data:image/png;base64," alt="Dunorte" style="height:32px;"/>
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
  </div>
  <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <img src="data:image/png;base64," alt="Dunorte Truck"/>
      <div class="tagline">Central de Relatórios</div>
    </div>
    <div class="nav-group">
      <div class="nav-label">Início</div>
      <button class="nav-item active" onclick="showPage('home',this)">🏠 Painel Inicial</button>
    </div>
    <div class="nav-group">
      <div class="nav-label">Relatórios</div>
      <button class="nav-item" onclick="showPage('cobranca',this)">💰 Cobrança</button>
      <button class="nav-item" onclick="showPage('atendimento',this)">📞 Atendimento</button>
      <button class="nav-item" onclick="showPage('resultados',this)">📊 Resultados</button>
      <button class="nav-item" onclick="showPage('meta',this)">🎯 Meta e Bonificação</button>
      <button class="nav-item" onclick="showPage('pmo',this)">🗂️ Painel PMO</button>
    </div>
    <div class="sidebar-footer">
      <div class="user-email" id="user-email"></div>
      <button class="btn-logout" onclick="logout()">Sair</button>
    </div>
  </aside>
  <main class="main">
    <div class="topbar">
      <div class="topbar-title" id="page-title">Painel Inicial</div>
      <div class="topbar-date" id="page-date"></div>
    </div>
    <div id="home-content">
      <div class="welcome">
        <h2>Bem-vindo à Central de Relatórios</h2>
        <p>Selecione um relatório no menu lateral ou clique em um dos atalhos abaixo.</p>
      </div>
      <div class="cards-grid">
        <div class="rep-card" onclick="showPage('cobranca',null)"><div class="rep-card-icon">💰</div><div class="rep-card-title">Cobrança</div><div class="rep-card-sub">Painel Executivo</div></div>
        <div class="rep-card" onclick="showPage('atendimento',null)"><div class="rep-card-icon">📞</div><div class="rep-card-title">Atendimento</div><div class="rep-card-sub">Produtividade</div></div>
        <div class="rep-card" onclick="showPage('resultados',null)"><div class="rep-card-icon">📊</div><div class="rep-card-title">Resultados</div><div class="rep-card-sub">Apresentação Mensal</div></div>
        <div class="rep-card" onclick="showPage('meta',null)"><div class="rep-card-icon">🎯</div><div class="rep-card-title">Meta e Bonificação</div><div class="rep-card-sub">Indicadores</div></div>
        <div class="rep-card" onclick="showPage('pmo',null)"><div class="rep-card-icon">🗂️</div><div class="rep-card-title">Painel PMO</div><div class="rep-card-sub">Gestão Estratégica</div></div>
      </div>
    </div>
    <iframe id="report-frame" class="report-frame" style="display:none;"></iframe>
  </main>
</div>

<script>
const SUPABASE_URL='https://tbtfpdxfttnrzohltmkt.supabase.co';
const SUPABASE_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRidGZwZHhmdHRucnpvaGx0bWt0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4NDIzMTksImV4cCI6MjA5NzQxODMxOX0.Bb6561DsIn4kb4BERvjZ3LPiFGMwpa5lK7KiFdTrcqY';
const {createClient}=supabase;
const sb=createClient(SUPABASE_URL,SUPABASE_KEY);

// Reports encoded as base64 to avoid JS syntax issues
const R={
  cobranca:'',
  atendimento:'',
  resultados:'',
  meta:'',
  pmo:''
};

const titulos={home:'Painel Inicial',cobranca:'Cobrança — Painel Executivo',atendimento:'Atendimento — Produtividade',resultados:'Resultados — Maio',meta:'Meta e Bonificação',pmo:'Painel PMO'};

document.getElementById('page-date').textContent=new Date().toLocaleDateString('pt-BR',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

sb.auth.onAuthStateChange((event,session)=>{
  if(session){document.getElementById('login-screen').style.display='none';document.getElementById('app-screen').style.display='block';document.getElementById('user-email').textContent=session.user.email;}
  else{document.getElementById('login-screen').style.display='flex';document.getElementById('app-screen').style.display='none';}
});

async function login(){
  const email=document.getElementById('email').value;
  const senha=document.getElementById('senha').value;
  const btn=document.getElementById('btn-login');
  const err=document.getElementById('login-error');
  err.style.display='none';btn.innerHTML='<span class="spinner"></span> Entrando...';btn.disabled=true;
  const {error}=await sb.auth.signInWithPassword({email,password:senha});
  if(error){err.textContent='E-mail ou senha incorretos.';err.style.display='block';btn.innerHTML='Entrar';btn.disabled=false;}
}
async function logout(){await sb.auth.signOut();}
document.getElementById('senha').addEventListener('keydown',e=>{if(e.key==='Enter')login();});

function b64decode(str){
  return decodeURIComponent(escape(atob(str)));
}

function showPage(page,btn){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(btn)btn.classList.add('active');
  document.getElementById('page-title').textContent=titulos[page]||page;
  const home=document.getElementById('home-content');
  const frame=document.getElementById('report-frame');
  if(page==='home'){home.style.display='block';frame.style.display='none';}
  else{
    home.style.display='none';frame.style.display='block';
    const html=b64decode(R[page]);
    const blob=new Blob([html],{type:'text/html;charset=utf-8'});
    const url=URL.createObjectURL(blob);
    frame.src=url;
  }
  closeSidebar();
}

function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('sidebar-overlay').classList.toggle('open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sidebar-overlay').classList.remove('open');}
</script>
</body>
</html>
